generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String       @id @default(cuid())
  name           String       
  email          String       @unique
  password       String
  role           String       @default("TEACHER") // ADMIN, DEAN, HOD, TEACHER
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id])
  facultyId      String?
  faculty        Faculty?     @relation(fields: [facultyId], references: [id])
  avatarUrl      String?      // Avatarlar uchun qo'shildi
  isDeleted      Boolean      @default(false)
  points         Int          @default(0) // KPI Gamification reytingi
  tasks          Task[]
  news           News[]
  taskSubmissions TaskSubmission[]
  comments       Comment[]
  logs           ActivityLog[]
  notifications  Notification[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Faculty {
  id             String       @id @default(cuid())
  name           String
  description    String?
  departments    Department[]
  users          User[]
  plans          Plan[]
  isDeleted      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Department {
  id             String       @id @default(cuid())
  name           String
  description    String?
  facultyId      String?
  faculty        Faculty?     @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  users          User[]
  plans          Plan[]
  isDeleted      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Plan {
  id             String       @id @default(cuid())
  title          String
  year           Int
  status         String       @default("DRAFT")
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id])
  facultyId      String?
  faculty        Faculty?     @relation(fields: [facultyId], references: [id])
  userId         String?
  tasks          Task[]
  isDeleted      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?
  deadline       DateTime?
  timeframe      String?      // Masalan: "2024-yil, avgust"
  note           String?      // Izoh
  status         String       @default("NEW")
  assignedRole   String?      // Masalan: "TEACHER", "HOD", "DEAN"
  fileUrl        String?      // Biriktirilgan hujjat manzili
  userId         String?
  user           User?        @relation(fields: [userId], references: [id])
  planId         String
  plan           Plan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  submissions    TaskSubmission[]
  comments       Comment[]
  isDeleted      Boolean      @default(false)
  pointsReward   Int          @default(10)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model TaskSubmission {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  note       String?  
  fileUrl    String?  
  createdAt  DateTime @default(now())
}

model News {
  id             String       @id @default(cuid())
  title          String
  content        String
  type           String       @default("UNIVERSITET") // UNIVERSITET yoki TALIM
  authorId       String
  author         User         @relation(fields: [authorId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String?
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}
