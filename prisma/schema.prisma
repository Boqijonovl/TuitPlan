generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String       @id @default(cuid())
  name           String       
  email          String       @unique
  password       String
  role           String       @default("OQITUVCHI") // ADMIN, DEKAN, MUDIR, OQITUVCHI
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id])
  facultyId      String?
  faculty        Faculty?     @relation(fields: [facultyId], references: [id])
  avatarUrl      String?      // Avatarlar uchun qo'shildi
  isDeleted      Boolean      @default(false)
  points         Int          @default(0) // KPI Gamification reytingi
  lastSeen       DateTime?    // Chat 'Online' statusi uchun
  tasks          Task[]
  news           News[]
  taskSubmissions TaskSubmission[]
  comments       Comment[]
  logs           ActivityLog[]
  notifications  Notification[]
  sentMessages     ChatMessage[] @relation("SentMessages")
  receivedMessages ChatMessage[] @relation("ReceivedMessages")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([role])
  @@index([facultyId])
  @@index([departmentId])
  @@index([email])
}

model Faculty {
  id             String       @id @default(cuid())
  name           String
  description    String?
  departments    Department[]
  users          User[]
  plans          Plan[]
  isDeleted      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Department {
  id             String       @id @default(cuid())
  name           String
  description    String?
  facultyId      String?
  faculty        Faculty?     @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  users          User[]
  plans          Plan[]
  isDeleted      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Plan {
  id             String       @id @default(cuid())
  title          String
  year           Int
  status         String       @default("DRAFT")
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id])
  facultyId      String?
  faculty        Faculty?     @relation(fields: [facultyId], references: [id])
  userId         String?
  tasks          Task[]
  isDeleted      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([status])
  @@index([departmentId])
  @@index([facultyId])
  @@index([userId])
}

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?
  deadline       DateTime?
  timeframe      String?      // Masalan: "2024-yil, avgust"
  note           String?      // Izoh
  status         String       @default("NEW")
  assignedRole   String?      // Masalan: "OQITUVCHI", "MUDIR", "DEKAN"
  fileUrl        String?      // Biriktirilgan hujjat manzili
  userId         String?
  user           User?        @relation(fields: [userId], references: [id])
  planId         String
  plan           Plan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  submissions    TaskSubmission[]
  comments       Comment[]
  isDeleted      Boolean      @default(false)
  pointsReward   Int          @default(10)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([status])
  @@index([planId])
  @@index([assignedRole])
  @@index([userId])
}

model TaskSubmission {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  note       String?  
  fileUrl    String?  
  fileHash   String?  // Anti-Cheat: Plagiat fayllar shifri
  fileSize   Int?     // Fayl hajmi
  originalName String? // Faylning asl nomi
  createdAt  DateTime @default(now())

  @@index([taskId])
  @@index([userId])
}

model News {
  id             String       @id @default(cuid())
  title          String
  content        String
  type           String       @default("UNIVERSITET") // UNIVERSITET yoki TALIM
  authorId       String
  author         User         @relation(fields: [authorId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String?
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

model ChatMessage {
  id         String   @id @default(cuid())
  text       String
  senderId   String
  receiverId String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  isRead     Boolean  @default(false)
  fileUrl    String?
  fileType   String?
  fileName   String?
  isEdited   Boolean  @default(false)
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model CustomRole {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions String[]
  createdAt   DateTime @default(now())
}

model SystemSetting {
  id               String   @id @default("GLOBAL")
  maintenanceMode  Boolean  @default(false)
  broadcastMessage String?
  broadcastActive  Boolean  @default(false)
  academicYear     String   @default("2026-2027")
  lockStructure    Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}

model BlockchainLedger {
  id           String   @id @default(cuid())
  entityType   String   // "PLAN", "TASK", "KPI"
  entityId     String
  action       String   // "APPROVED", "SUBMITTED", "POINTS_AWARDED"
  dataPayload  String   // JSON shifrlangan holat (Snapshot)
  previousHash String   // Zanjirning o'tgan tuguni
  currentHash  String   @unique // Hozirgi tugun shifri
  timestamp    DateTime @default(now())

  @@index([entityType])
  @@index([entityId])
  @@index([currentHash])
}
